// ===================================================
// WIP: 動確　build:deploy
// ===================================================
{
  "version": "2.0.0",
  "tasks": [
    // ===================================================
    // Build: WAR を作成
    // ===================================================
    {
      "label": "build",
      "detail": "mvn clean package で WAR ファイルを生成します",
      "type": "shell",
      "command": "mvn clean package -DskipTests",
      "options": {
        "cwd": "${workspaceFolder}/${input:project}"
      },
      "group": {
        "kind": "build",
        "isDefault": true // Ctrl+Shift+B に割り当て
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": "$maven"
    },
    // ===================================================
    // Deploy: WAR を Tomcat の webapps/ にコピー 
    // ===================================================
    {
      "label": "deploy",
      "detail": "ビルド済みの WAR を Tomcat の webapps/ にコピーします",
      "type": "shell",
      // TOMCAT_HOME が未設定の場合は /opt/tomcat にフォールバック
      "command": "cp ${workspaceFolder}/${input:project}/target/${input:project}.war ${workspaceFolder}/deploy/echo/restapi/",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    // ===================================================
    // Build & Deploy
    // ===================================================
    {
      "label": "build & deploy",
      "detail": "ビルドしてそのまま Tomcat にデプロイします",
      "dependsOrder": "sequence", // build が終わってから deploy を実行
      "dependsOn": [
        "build",
        "deploy"
      ],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    // ===================================================
    // Test: テストを実行 TODO:inputs で選択
    // ===================================================
    {
      "label": "test",
      "detail": "mvn test でテストを実行します",
      "type": "shell",
      "command": "mvn test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": "$maven"
    },
    // ===================================================
    // Tomcat: ログを流す TODO:inputs で選択
    // ===================================================
    {
      "label": "tomcat:log",
      "detail": "product-a-1 のログをリアルタイムで表示します",
      "type": "shell",
      "command": "docker compose logs -f product-a-1",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    // ===================================================
    // Docker: profile単位で起動
    // ===================================================
    {
      "label": "docker:up:profile",
      "detail": "指定したprofileのコンテナを起動します",
      "type": "shell",
      "command": "docker compose --profile ${input:profile} up -d",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    // ===================================================
    // Docker: コンテナ単体で起動
    // ===================================================
    {
      "label": "docker:up:container",
      "detail": "指定したコンテナを単体で起動します",
      "type": "shell",
      "command": "docker compose up -d ${input:container}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    // ===================================================
    // Docker: profile単位で停止
    // ===================================================
    {
      "label": "docker:down:profile",
      "detail": "指定したprofileのコンテナを停止します",
      "type": "shell",
      "command": "docker compose --profile ${input:profile} down",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    // ===================================================
    // Docker: コンテナ単体で停止
    // ===================================================
    {
      "label": "docker:down:container",
      "detail": "指定したコンテナを単体で停止します",
      "type": "shell",
      "command": "docker compose stop ${input:container}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    // ===================================================
    // Docker: profile単位で再ビルド
    // ===================================================
    {
      "label": "docker:rebuild:profile",
      "detail": "指定したprofileのイメージを再ビルドして起動します",
      "type": "shell",
      "command": "docker compose --profile ${input:profile} up -d --build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    // ===================================================
    // Docker: コンテナ単体で再ビルド
    // ===================================================
    {
      "label": "docker:rebuild:container",
      "detail": "指定したコンテナを再ビルドして起動します",
      "type": "shell",
      "command": "docker compose up -d --build ${input:container}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "profile",
      "type": "pickString",
      "description": "起動するprofileを選択してください",
      "options": [
        "echo",
        "message"
      ]
    },
    {
      "id": "container",
      "type": "pickString",
      "description": "起動するコンテナを選択してください",
      "options": [
        "echo-restapi",
        "echo-web",
        "message-web"
      ]
    },
    {
      "id": "project",
      "type": "pickString",
      "description": "プロジェクトを選択してください",
      "options": [
        "Echo-RestAPI",
        "Echo-Web",
        "Message-Web"
      ]
    }
  ]
}